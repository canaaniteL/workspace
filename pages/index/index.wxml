<view class="page">
  <view wx:if="{{loading}}" class="loading-mask">
    <text class="loading-text">加载题库中...</text>
  </view>

  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="top-left">
      <text class="mode-tag" wx:if="{{mode === 'review'}}">复习模式</text>
      <text class="stat-brief">已评 {{ratedCount}}/{{total}} · 平均 {{avgScore}}</text>
    </view>
    <view class="deck-selector" bindtap="showDeckPicker">
      <text>{{currentDeckName}}</text>
      <text class="deck-arrow">▼</text>
    </view>
  </view>

  <!-- 卡片滑动区 -->
  <view class="swiper-wrap">
    <swiper
      class="card-swiper"
      current="{{index}}"
      bindchange="onSwiperChange"
      duration="250"
      easing-function="easeOutCubic"
    >
      <swiper-item wx:for="{{list}}" wx:key="index">
        <view class="card" bindtap="toggleAnswer">
          <view class="card-header">
            <text class="progress">{{index + 1}} / {{total}}</text>
            <view class="header-right">
              <view
                wx:if="{{ratings[index]}}"
                class="rating-badge"
                style="background: {{ratings[index] <= 2 ? '#EF4444' : ratings[index] <= 3 ? '#EAB308' : '#22C55E'}};"
              >{{ratings[index]}}</view>
            </view>
          </view>

          <view class="card-body">
            <!-- 代码视图 -->
            <block wx:if="{{currentIndex === index && showAnswer === 2 && item.code}}">
              <scroll-view scroll-y class="code-scroll">
                <text class="code-text">{{item.code}}</text>
              </scroll-view>
            </block>
            <!-- 答案/思路视图 -->
            <block wx:elif="{{currentIndex === index && showAnswer === 1}}">
              <text class="a-text">{{item.a}}</text>
            </block>
            <!-- 题面视图 -->
            <block wx:else>
              <text class="q-text">{{item.q}}</text>
            </block>
          </view>

          <view class="card-footer">
            <text class="hint" wx:if="{{currentIndex === index && showAnswer === 2}}">返回题面</text>
            <text class="hint" wx:elif="{{currentIndex === index && showAnswer === 1}}">返回题面</text>
            <text class="hint" wx:else>查看答案</text>
            <text class="code-link" wx:if="{{currentIndex === index && showAnswer === 1 && item.code}}" catchtap="showCode">📝 查看代码</text>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <cover-view class="float-shuffle" bindtap="shuffleList">🔀</cover-view>
    <cover-view class="float-menu" bindtap="showMenu">⋮</cover-view>
    <cover-view class="float-feedback" bindtap="goFeedback">反馈</cover-view>
    <cover-view class="float-tts" bindtap="playTTS" wx:if="{{hasTTS}}">🔊</cover-view>
  </view>

  <!-- 评分面板 -->
  <view class="rating-panel" wx:if="{{showRating}}">
    <text class="rating-title">评价掌握程度</text>
    <view class="rating-row">
      <view
        wx:for="{{[1,2,3,4,5]}}"
        wx:key="*this"
        class="rating-btn {{currentRating === item ? 'rating-active' : ''}}"
        style="border-color: {{item <= 2 ? '#EF4444' : item <= 3 ? '#EAB308' : '#22C55E'}}; {{currentRating === item ? 'background:' + (item <= 2 ? '#EF4444' : item <= 3 ? '#EAB308' : '#22C55E') + ';color:#fff;' : ''}}"
        catchtap="rateQuestion"
        data-score="{{item}}"
      >
        <text class="rating-num">{{item}}</text>
      </view>
    </view>
    <view class="rating-labels">
      <text class="rl-left">完全不会</text>
      <text class="rl-right">完全掌握</text>
    </view>
  </view>

  <!-- 来源 -->
  <view class="source-bar">
    <text class="source-tag">{{currentDeckName}} · {{source === 'remote' ? '☁️ 云端' : source === 'local' ? '📁 缓存' : '📦 内置'}}</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="toolbar">
    <view class="tool-btn circle" catchtap="goPrev"><text class="arrow">←</text></view>
    <view class="tool-btn pill wrong" catchtap="markWrong"><text class="icon-x">✕</text><text class="count">{{wrongCount}}</text></view>
    <view class="tool-btn pill rate-btn" catchtap="showRatingPanel"><text class="rate-icon">★</text><text class="count">评分</text></view>
    <view class="tool-btn pill right" catchtap="markRight"><text class="count">{{rightCount}}</text><text class="icon-ok">✓</text></view>
    <view class="tool-btn circle" catchtap="goNext"><text class="arrow">→</text></view>
  </view>
</view>
