<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-mask">
    <text class="loading-text">加载题库中...</text>
  </view>

  <!-- 卡片区 -->
  <view
    class="card"
    style="transform: translateX({{translateX}}px);"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
    bindtap="toggleAnswer"
  >
    <view class="card-header">
      <text class="progress">{{index + 1}} / {{total}}</text>
      <view class="menu" catchtap="showMenu">⋮</view>
    </view>

    <view class="card-body">
      <block wx:if="{{total === 0}}">
        <text class="q-text">暂无题目\n点右上角 ⋮ 导入 CSV</text>
      </block>
      <block wx:elif="{{!showAnswer}}">
        <text class="q-text">{{list[index].q}}</text>
      </block>
      <block wx:else>
        <text class="a-text">{{list[index].a}}</text>
      </block>
    </view>

    <view class="card-footer">
      <text class="hint" wx:if="{{total > 0}}">{{showAnswer ? '收起答案' : '查看答案'}}</text>
      <text class="source-tag">{{source === 'remote' ? '☁️ 云端' : source === 'local' ? '📁 导入' : '📦 内置'}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="toolbar">
    <view class="tool-btn circle" catchtap="goPrev">
      <text class="arrow">←</text>
    </view>

    <view class="tool-btn pill wrong" catchtap="markWrong">
      <text class="icon-x">✕</text>
      <text class="count">{{wrongCount}}</text>
    </view>

    <view class="tool-btn pill right" catchtap="markRight">
      <text class="count">{{rightCount}}</text>
      <text class="icon-ok">✓</text>
    </view>

    <view class="tool-btn circle" catchtap="goNext">
      <text class="arrow">→</text>
    </view>
  </view>
</view>
