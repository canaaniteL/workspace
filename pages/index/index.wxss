.page {
  height: 100vh;
  padding: 24rpx 36rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: #F5F7FB;
}

/* 顶部信息栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  min-height: 44rpx;
}
.top-left { display: flex; align-items: center; gap: 12rpx; }
.deck-selector {
  display: flex; align-items: center; gap: 8rpx;
  padding: 10rpx 22rpx; background: #fff; border: 2rpx solid #E5E7EF;
  border-radius: 28rpx; font-size: 24rpx; color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.deck-arrow { font-size: 18rpx; color: #999; }
.mode-tag {
  font-size: 22rpx; color: #fff; background: #EF4444;
  padding: 4rpx 16rpx; border-radius: 20rpx;
}
.stat-brief { font-size: 22rpx; color: #999; }

/* Swiper */
.swiper-wrap { position: relative; flex: 1; }
.card-swiper { width: 100%; height: 100%; }

/* 浮动按钮 */
.float-shuffle {
  position: absolute; top: 26rpx; right: 104rpx;
  width: 64rpx; height: 64rpx; font-size: 34rpx;
  text-align: center; line-height: 64rpx; z-index: 20;
  color: rgba(255, 255, 255, 0.55);
}
.float-menu {
  position: absolute; top: 22rpx; right: 24rpx;
  width: 80rpx; height: 80rpx; font-size: 48rpx;
  color: rgba(255, 255, 255, 0.65); text-align: center;
  line-height: 80rpx; z-index: 20;
}
.float-feedback {
  position: absolute; bottom: 22rpx; right: 24rpx;
  font-size: 22rpx; color: rgba(255, 255, 255, 0.35);
  padding: 16rpx 20rpx; z-index: 20;
}
.float-tts {
  position: absolute; bottom: 18rpx; left: 24rpx;
  width: 76rpx; height: 76rpx; font-size: 38rpx;
  text-align: center; line-height: 76rpx; z-index: 20;
  background: rgba(255, 255, 255, 0.12); border-radius: 50%;
  color: rgba(255, 255, 255, 0.75);
}

/* 卡片 */
.card {
  position: relative; width: 100%; height: 100%;
  background: linear-gradient(145deg, #2A2C31 0%, #1E2025 100%);
  border-radius: 36rpx;
  box-shadow: 0 20rpx 50rpx -8rpx rgba(74, 222, 128, 0.2),
              0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  color: #fff; padding: 44rpx; box-sizing: border-box;
  display: flex; flex-direction: column; overflow: hidden;
}
.card::after {
  content: ''; position: absolute; right: -140rpx; top: 50%;
  transform: translateY(-50%); width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, rgba(74, 222, 128, 0.35) 0%, rgba(74, 222, 128, 0) 65%);
  pointer-events: none;
}

.card-header {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 28rpx; color: rgba(255, 255, 255, 0.5);
}
.header-right { display: flex; align-items: center; gap: 12rpx; }
.rating-badge {
  width: 44rpx; height: 44rpx; border-radius: 50%; color: #fff;
  font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

.card-body {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 24rpx 12rpx;
}
.q-text {
  font-size: 48rpx; line-height: 1.55; font-weight: 700;
  color: #fff; text-align: center; word-break: break-word;
  letter-spacing: 1rpx;
}
.a-text {
  font-size: 42rpx; line-height: 1.6; font-weight: 500;
  color: #A7F3D0; text-align: center; word-break: break-word;
}

.card-footer {
  text-align: center; font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  display: flex; justify-content: center; align-items: center; gap: 24rpx;
}
.hint { padding: 12rpx 32rpx; }
.code-link {
  font-size: 22rpx; color: #A7F3D0; padding: 10rpx 22rpx;
  background: rgba(74,222,128,0.12); border-radius: 20rpx;
}

/* 代码滚动区 */
.code-scroll { width: 100%; height: 100%; }
.code-text {
  font-size: 24rpx; line-height: 1.65; color: #e2e8f0;
  background: rgba(0,0,0,0.35); border-radius: 18rpx;
  padding: 24rpx; display: block; white-space: pre-wrap;
  font-family: 'Menlo', 'Consolas', monospace; word-break: break-all;
}

/* 评分面板 */
.rating-panel {
  background: #fff; border-radius: 24rpx;
  padding: 22rpx 28rpx; margin-top: 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.rating-title {
  font-size: 24rpx; color: #888; display: block;
  text-align: center; margin-bottom: 18rpx;
}
.rating-row { display: flex; justify-content: center; gap: 18rpx; }
.rating-btn {
  width: 76rpx; height: 76rpx; border-radius: 50%;
  border: 3rpx solid #ddd; display: flex;
  align-items: center; justify-content: center;
  background: #fff; transition: all 0.15s;
}
.rating-btn:active { transform: scale(0.92); }
.rating-active { transform: scale(1.08); }
.rating-num { font-size: 30rpx; font-weight: 700; color: #333; }
.rating-active .rating-num { color: #fff; }
.rating-labels {
  display: flex; justify-content: space-between;
  margin-top: 10rpx; padding: 0 12rpx;
}
.rl-left, .rl-right { font-size: 20rpx; color: #ccc; }

/* 来源 */
.source-bar { text-align: center; margin-top: 10rpx; }
.source-tag { font-size: 20rpx; color: rgba(0, 0, 0, 0.25); }

/* 底部操作栏 */
.toolbar {
  margin-top: 16rpx; display: flex; align-items: center;
  justify-content: space-between; padding: 0 8rpx;
}
.tool-btn {
  display: flex; align-items: center; justify-content: center;
  background: #fff; border: 2rpx solid #E5E7EF;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.1s;
}
.tool-btn:active { transform: scale(0.95); opacity: 0.85; }
.circle { width: 82rpx; height: 82rpx; border-radius: 50%; }
.arrow { font-size: 38rpx; color: #5B7CFA; }
.pill {
  min-width: 116rpx; height: 74rpx;
  border-radius: 42rpx; padding: 0 22rpx; gap: 8rpx;
}
.pill .count { font-size: 28rpx; font-weight: 600; color: #333; }
.wrong .icon-x { font-size: 32rpx; color: #EF4444; margin-right: 8rpx; font-weight: 700; }
.right .icon-ok { font-size: 32rpx; color: #22C55E; margin-left: 8rpx; font-weight: 700; }
.rate-btn { border-color: #EAB308; }
.rate-icon { font-size: 30rpx; color: #EAB308; margin-right: 6rpx; }

/* 加载 */
.loading-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3); display: flex;
  align-items: center; justify-content: center; z-index: 999;
}
.loading-text { color: #fff; font-size: 32rpx; }
