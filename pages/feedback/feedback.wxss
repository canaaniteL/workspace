.page {
  min-height: 100vh;
  background: #F5F7FB;
  padding: 32rpx;
  box-sizing: border-box;
}

/* 顶部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}
.add-btn {
  font-size: 28rpx;
  color: #fff;
  background: #5B7CFA;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}
.add-btn:active {
  opacity: 0.8;
}

/* 表单弹层 */
.form-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  padding: 40rpx;
}
.form-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.15);
  position: relative;
}
.close-btn {
  position: absolute;
  top: 20rpx;
  right: 28rpx;
  font-size: 36rpx;
  color: #bbb;
  padding: 10rpx;
  line-height: 1;
}

/* 类型切换 */
.type-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #999;
  border: 2rpx solid #E5E7EF;
  border-radius: 16rpx;
}
.tab-active {
  color: #5B7CFA;
  border-color: #5B7CFA;
  background: rgba(91, 124, 250, 0.06);
  font-weight: 600;
}

/* 表单字段 */
.field {
  margin-bottom: 24rpx;
}
.label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #E5E7EF;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.textarea {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid #E5E7EF;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.5;
}
.submit-btn {
  margin-top: 24rpx;
  text-align: center;
  background: #5B7CFA;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
  border-radius: 16rpx;
}
.submit-btn:active {
  opacity: 0.8;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.item-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.item-type {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
}
.type-q {
  background: rgba(34, 197, 94, 0.1);
  color: #22C55E;
}
.type-f {
  background: rgba(91, 124, 250, 0.1);
  color: #5B7CFA;
}
.item-time {
  font-size: 22rpx;
  color: #bbb;
  flex: 1;
}
.item-del {
  font-size: 22rpx;
  color: #EF4444;
  padding: 4rpx 12rpx;
}

/* 内容行 */
.item-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.item-label {
  font-size: 26rpx;
  color: #999;
  font-weight: 600;
  flex-shrink: 0;
}
.item-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-word;
}
.item-answer {
  color: #22C55E;
}
.item-related {
  color: #5B7CFA;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding-top: 200rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #bbb;
  line-height: 2;
}
